<svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="64" height="64" rx="16" fill="#DEFF0A"/>
  <!-- Tre cerchi centrali verticali (grandi) -->
  <circle cx="32" cy="24" r="4.5" fill="#1A1A1A"/>
  <circle cx="32" cy="32" r="4.5" fill="#1A1A1A"/>
  <circle cx="32" cy="40" r="4.5" fill="#1A1A1A"/>
  
  <!-- Quattro cerchi diagonali medi (formano diamante interno) -->
  <circle cx="22" cy="22" r="3.5" fill="#1A1A1A"/>
  <circle cx="42" cy="22" r="3.5" fill="#1A1A1A"/>
  <circle cx="22" cy="42" r="3.5" fill="#1A1A1A"/>
  <circle cx="42" cy="42" r="3.5" fill="#1A1A1A"/>
  
  <!-- Quattro cerchi piccoli ai punti cardinali -->
  <circle cx="32" cy="10" r="2.5" fill="#1A1A1A"/>
  <circle cx="32" cy="54" r="2.5" fill="#1A1A1A"/>
  <circle cx="10" cy="32" r="2.5" fill="#1A1A1A"/>
  <circle cx="54" cy="32" r="2.5" fill="#1A1A1A"/>
</svg>
